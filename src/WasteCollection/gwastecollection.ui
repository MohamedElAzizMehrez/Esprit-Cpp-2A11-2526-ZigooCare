    selection-color: white;
}

QTableView::item {
    padding: 6px;
    border: none;
}

QTableView::item:hover {
    background-color: rgba(1, 138, 218, 0.15);
}

QTableView::item:selected {
    background-color: #018ADA;
    color: white;
}

QHeaderView::section {
    background-color: #32485F;
    color: white;
    padding: 6px;
    border: 1px solid #32485F;
    font-weight: bold;
}

QHeaderView::section:checked {
    background-color: #018ADA;
}

QScrollBar:vertical {
    background: #8DA2B5;
    width: 10px;
}

QScrollBar::handle:vertical {
    background: #32485F;
    border-radius: 4px;
}

QScrollBar::handle:vertical:hover {
    background: #018ADA;
}

QScrollBar:horizontal {
    background: #8DA2B5;
    height: 10px;
}

QScrollBar::handle:horizontal {
    background: #32485F;
    border-radius: 4px;
}

QScrollBar::handle:horizontal:hover {
    background: #018ADA;
}</string>
